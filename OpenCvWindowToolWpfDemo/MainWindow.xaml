<Window x:Class="OpenCvWindowToolWpfDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:OpenCvWindowToolWpfDemo.Controls"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="OpenCV 直线检测"
        Width="1320"
        Height="860"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2F6FED" />
        <SolidColorBrush x:Key="NavBrush" Color="#20242A" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D7DCE2" />

        <Style x:Key="ModuleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="10,5" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#30363E" />
            <Setter Property="BorderBrush" Value="#30363E" />
            <Setter Property="FontSize" Value="14" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,10,0,4" />
            <Setter Property="Foreground" Value="#444444" />
        </Style>

        <Style x:Key="DirectionButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Foreground" Value="#1E2329" />
            <Setter Property="Background" Value="#F7F8FA" />
            <Setter Property="BorderBrush" Value="#C8D0DA" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#F4F5F7">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource NavBrush}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="直线检测"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="16,18,16,14" />
                <StackPanel>
                    <ToggleButton Content="输入图像"
                                  Style="{StaticResource ModuleButtonStyle}"
                                  IsChecked="{Binding IsInputModule, Mode=OneWay}"
                                  Command="{Binding ShowInputCommand}" />
                    <ToggleButton Content="ROI"
                                  Style="{StaticResource ModuleButtonStyle}"
                                  IsChecked="{Binding IsRoiModule, Mode=OneWay}"
                                  Command="{Binding ShowRoiCommand}" />
                    <ToggleButton Content="参数设置"
                                  Style="{StaticResource ModuleButtonStyle}"
                                  IsChecked="{Binding IsParamsModule, Mode=OneWay}"
                                  Command="{Binding ShowParamsCommand}" />
                    <ToggleButton Content="结果输出"
                                  Style="{StaticResource ModuleButtonStyle}"
                                  IsChecked="{Binding IsResultModule, Mode=OneWay}"
                                  Command="{Binding ShowResultCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Column="1"
                Margin="10"
                Background="Black"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1">
            <wfi:WindowsFormsHost x:Name="FormsHost" />
        </Border>

        <Border Grid.Column="2"
                Background="White"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="18">
                    <StackPanel Visibility="{Binding IsInputModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="输入图像" Style="{StaticResource PanelTitleStyle}" />
                        <Button Content="导入图像"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding OpenImageCommand}" />
                        <Button Content="保存当前图像"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding SaveImageCommand}" />
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="#666666"
                                   Text="{Binding ImageStatus}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsRoiModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="ROI" Style="{StaticResource PanelTitleStyle}" />
                        <Button Content="创建矩形检测ROI"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding CreateRectangleRoiCommand}" />
                        <Button Content="创建带角度矩形ROI"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding CreateRotatedRectangleRoiCommand}" />
                        <Button Content="清除ROI"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding ClearRoiCommand}" />
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="#666666"
                                   Text="{Binding RoiStatus}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsParamsModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="参数设置" Style="{StaticResource PanelTitleStyle}" />

                        <TextBlock Text="ROI检测方向" Style="{StaticResource FieldLabelStyle}" />
                        <UniformGrid Columns="4">
                            <ToggleButton Content="→"
                                          Style="{StaticResource DirectionButtonStyle}"
                                          IsChecked="{Binding IsLeftToRight, Mode=OneWay}"
                                          Command="{Binding SetLeftToRightCommand}" />
                            <ToggleButton Content="↓"
                                          Style="{StaticResource DirectionButtonStyle}"
                                          IsChecked="{Binding IsTopToBottom, Mode=OneWay}"
                                          Command="{Binding SetTopToBottomCommand}" />
                            <ToggleButton Content="↑"
                                          Style="{StaticResource DirectionButtonStyle}"
                                          IsChecked="{Binding IsBottomToTop, Mode=OneWay}"
                                          Command="{Binding SetBottomToTopCommand}" />
                            <ToggleButton Content="←"
                                          Style="{StaticResource DirectionButtonStyle}"
                                          Margin="0"
                                          IsChecked="{Binding IsRightToLeft, Mode=OneWay}"
                                          Command="{Binding SetRightToLeftCommand}" />
                        </UniformGrid>

                        <TextBlock Text="ROI边缘极性" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding PolarityOptions}"
                                  SelectedItem="{Binding SelectedPolarity, Mode=TwoWay}" />

                        <TextBlock Text="边缘选择方式" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding SelectionModeOptions}"
                                  SelectedItem="{Binding SelectedSelectionMode, Mode=TwoWay}" />

                        <TextBlock Text="拟合直线方式" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding FitModeOptions}"
                                  SelectedItem="{Binding SelectedFitMode, Mode=TwoWay}" />

                        <TextBlock Text="边缘阈值" Style="{StaticResource FieldLabelStyle}" />
                        <controls:NumericInputBox Value="{Binding Threshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Minimum="0"
                                                  Maximum="1000"
                                                  Increment="1"
                                                  ValueKind="Float" />

                        <TextBlock Text="检测点个数" Style="{StaticResource FieldLabelStyle}" />
                        <controls:NumericInputBox Value="{Binding SampleCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Minimum="2"
                                                  Maximum="500"
                                                  Increment="1"
                                                  ValueKind="Integer" />

                        <Border Margin="0,16,0,0"
                                Padding="10"
                                Background="#F7F8FA"
                                BorderBrush="#E1E5EA"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="检测结果" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding LiveStatus}"
                                           Foreground="{Binding LiveStatusBrush}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding LiveLine}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsResultModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="结果输出" Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="{Binding ResultStatus}"
                                   Foreground="{Binding ResultStatusBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,12,0,0" Text="{Binding ResultStart}" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding ResultEnd}" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding ResultAngle}" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding ResultPointCount}" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding ResultAverageStrength}" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding ResultMaxStrength}" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding ResultDirection}" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding ResultElapsed}" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
